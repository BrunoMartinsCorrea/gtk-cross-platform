{
  "app-id": "com.example.GtkCrossPlatform",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "gtk-cross-platform",
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/gtk-cross-platform/cargo",
      "RUST_BACKTRACE": "1",
      "APP_ID": "com.example.GtkCrossPlatform",
      "PROFILE": "default",
      "PKGDATADIR": "/app/share/gtk-cross-platform",
      "LOCALEDIR": "/app/share/locale"
    }
  },
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/aclocal",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "gtk-cross-platform",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release",
        "install -Dm755 target/release/gtk-cross-platform /app/bin/gtk-cross-platform",
        "install -Dm644 data/icons/hicolor/scalable/apps/com.example.GtkCrossPlatform.svg /app/share/icons/hicolor/scalable/apps/com.example.GtkCrossPlatform.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        },
        "cargo-sources.json"
      ]
    }
  ]
}
