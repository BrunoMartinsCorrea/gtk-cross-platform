# --- Rust / Cargo ---
# Cargo.lock is tracked because this is a binary application (has [[bin]] in Cargo.toml)
target/

# --- Build systems ---
# Meson / Ninja
build/
builddir/
_build/
.ninja_deps
.ninja_log

# --- GTK / GLib generated files ---
# Compiled GResource bundles — regenerated at build time by glib-build-tools
*.gresource
# Compiled GSettings schemas — regenerated by `make schema` / glib-compile-schemas
data/gschemas.compiled
# Vala-generated C/H intermediaries — never edit directly
*.c
*.h
*.o
*.vapi

# --- Gettext / i18n ---
# Compiled translation catalogs — generated from *.po sources during build
*.mo

# --- Flatpak / AppStream ---
.flatpak-builder/
flatpak-build/
repo/
*.flatpak
*.oci

# --- Distribution packages ---
*.deb
*.rpm
*.AppImage
*.dmg
# macOS app bundle — assembled by `make dmg`, not hand-authored
*.app/

# --- Platform binaries ---
# Windows executable (cross-platform project targets Win32/MSYS2)
*.exe
# macOS/Windows icon bundles — generated by `make icons-macos` / `make icons-windows`
*.icns
*.ico

# --- Secrets and credentials ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.*

# --- Test / coverage artifacts ---
lcov.info
coverage/
tarpaulin-report.*
*.profraw
*.profdata

# --- Logs and crash dumps ---
*.log
crash-*.txt
sanitizer-*.txt

# --- Temporary and editor swap files ---
*.tmp
*.bak
*.orig
*.swp
*.swo
*~
\#*\#
.\#*

# --- IDE and editor ---
# JetBrains (IntelliJ, CLion, RustRover)
.idea/
*.iml
*.iws
out/

# VS Code
.vscode/
*.code-workspace

# Xcode (macOS cross-platform target)
*.xcodeproj/
*.xcworkspace/
DerivedData/

# Sublime Text
*.sublime-project
*.sublime-workspace

# --- OS artifacts ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# --- Project-local tooling (not published source) ---
.prompt/
.claude/docs/reports/
.claude/prompts/
