root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.toml]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.ui]
indent_size = 2

[*.xml]
indent_size = 2

[*.css]
indent_size = 2

[meson.build]
indent_size = 2

[*.rs]
# cargo fmt is the authority on Rust indentation; string continuation
# lines in format!() macros use alignment spacing, not structural indent.
indent_size = unset
