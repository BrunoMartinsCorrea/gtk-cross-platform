<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GtkCrossPlatformMainWindow" parent="AdwApplicationWindow">
    <property name="title" translatable="yes">Container Manager</property>
    <property name="default-width">1100</property>
    <property name="default-height">640</property>
    <child>
      <!--
        Outer AdwToolbarView owns the single, full-width header bar.
        AdwNavigationSplitView is the content — its pages have no inner header bar,
        so the tab switcher and window controls always span the full window width.
      -->
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwBanner" id="runtime_banner">
            <property name="title" translatable="yes">No container runtime found. Install Docker, Podman, or containerd.</property>
            <property name="button-label" translatable="yes">Retry</property>
            <property name="revealed">false</property>
          </object>
        </child>
        <child type="top">
          <object class="AdwHeaderBar" id="header_bar">
            <child type="start">
              <object class="GtkMenuButton" id="menu_button">
                <property name="icon-name">open-menu-symbolic</property>
                <property name="tooltip-text" translatable="yes">Main Menu</property>
                <property name="menu-model">primary_menu</property>
                <style>
                  <class name="action-button"/>
                </style>
              </object>
            </child>
            <child type="title">
              <object class="AdwViewSwitcher" id="view_switcher_top">
                <property name="stack">view_stack</property>
                <property name="policy">wide</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkSpinner" id="spinner">
                <property name="visible">false</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="refresh_button">
                <property name="icon-name">view-refresh-symbolic</property>
                <property name="tooltip-text" translatable="yes">Refresh</property>
                <accessibility>
                  <property name="label" translatable="yes">Refresh</property>
                </accessibility>
                <style>
                  <class name="action-button"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child type="bottom">
          <object class="AdwViewSwitcherBar" id="view_switcher_bar">
            <property name="stack">view_stack</property>
            <property name="reveal">false</property>
          </object>
        </child>
        <property name="content">
          <object class="AdwToastOverlay" id="toast_overlay">
            <property name="child">
              <object class="AdwNavigationSplitView" id="split_view">
                <property name="max-sidebar-width">320</property>
                <property name="sidebar">
                  <object class="AdwNavigationPage" id="sidebar_page">
                    <property name="title" translatable="yes">Container Manager</property>
                    <property name="child">
                      <!--
                        Children (Containers/Images/Volumes/Networks) are added
                        programmatically in MainWindow::setup_views() so each
                        view module owns its own widget tree.
                      -->
                      <object class="AdwViewStack" id="view_stack"/>
                    </property>
                  </object>
                </property>
                <property name="content">
                  <object class="AdwNavigationPage" id="content_page">
                    <property name="title" translatable="yes"></property>
                    <property name="child">
                      <object class="GtkStack" id="detail_stack">
                        <property name="vexpand">true</property>
                        <property name="transition-type">slide-left-right</property>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">empty</property>
                            <property name="child">
                              <object class="AdwStatusPage" id="detail_status_page">
                                <property name="vexpand">true</property>
                                <property name="valign">center</property>
                                <property name="title" translatable="yes">No Selection</property>
                                <property name="description" translatable="yes">Select an item from the list to view its details.</property>
                                <property name="icon-name">view-list-symbolic</property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage">
                            <property name="name">detail</property>
                            <property name="child">
                              <object class="GtkScrolledWindow">
                                <property name="hscrollbar-policy">never</property>
                                <property name="vexpand">true</property>
                                <property name="child">
                                  <object class="GtkBox" id="detail_content">
                                    <property name="orientation">vertical</property>
                                    <property name="margin-top">48</property>
                                    <property name="margin-bottom">48</property>
                                    <property name="margin-start">48</property>
                                    <property name="margin-end">48</property>
                                    <property name="spacing">12</property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>
      </object>
    </child>

    <!-- Desktop compact ≤ 768sp: margins 32sp -->
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 768sp</condition>
        <setter object="detail_content" property="margin-start">32</setter>
        <setter object="detail_content" property="margin-end">32</setter>
        <setter object="detail_content" property="margin-top">32</setter>
        <setter object="detail_content" property="margin-bottom">32</setter>
      </object>
    </child>

    <!-- Tablet ≤ 600sp: margins 24sp -->
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 600sp</condition>
        <setter object="detail_content" property="margin-start">24</setter>
        <setter object="detail_content" property="margin-end">24</setter>
        <setter object="detail_content" property="margin-top">24</setter>
        <setter object="detail_content" property="margin-bottom">24</setter>
      </object>
    </child>

    <!-- Navigation split view collapses at 900sp; gives ViewSwitcher tabs room to render untruncated -->
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 900sp</condition>
        <setter object="split_view" property="collapsed">true</setter>
        <setter object="view_switcher_bar" property="reveal">true</setter>
        <setter object="view_switcher_top" property="visible">false</setter>
      </object>
    </child>

    <!-- GNOME Mobile ≤ 360sp: margins 16sp -->
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 360sp</condition>
        <setter object="detail_content" property="margin-start">16</setter>
        <setter object="detail_content" property="margin-end">16</setter>
        <setter object="detail_content" property="margin-top">16</setter>
        <setter object="detail_content" property="margin-bottom">16</setter>
      </object>
    </child>

    <!-- Component-local keyboard shortcuts (scope=local → only when window has focus) -->
    <child>
      <object class="GtkShortcutController">
        <property name="scope">local</property>
        <child>
          <object class="GtkShortcut">
            <property name="trigger">&lt;Primary&gt;f</property>
            <property name="action">action(win.focus-search)</property>
          </object>
        </child>
        <child>
          <object class="GtkShortcut">
            <property name="trigger">Escape</property>
            <property name="action">action(win.clear-search)</property>
          </object>
        </child>
      </object>
    </child>

  </template>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Prune System…</attribute>
        <attribute name="action">win.prune-system</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About Container Manager</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
</interface>
