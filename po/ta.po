#: src/window/main_window.rs
msgid "Containers"
msgstr "கண்டெயினர்கள்"

#: src/window/main_window.rs
msgid "Images"
msgstr "படங்கள்"

#: src/window/main_window.rs
msgid "Volumes"
msgstr "தொகுதிகள்"

#: src/window/main_window.rs
msgid "Networks"
msgstr "நெட்வொர்க்குகள்"

#: src/window/main_window.rs
msgid "Prune System?"
msgstr "கணினியை சுத்தம் செய்யவா?"

#: src/window/main_window.rs
msgid ""
"This will remove all stopped containers, dangling images, and unused "
"networks. This cannot be undone."
msgstr ""
"இது அனைத்து நிறுத்தப்பட்ட கண்டெயினர்கள், தொங்கும் படங்கள் மற்றும் "
"பயன்படுத்தப்படாத நெட்வொர்க்குகளை நீக்கும். இதை செயல்தவிர்க்க முடியாது."

#: src/window/main_window.rs
msgid "Prune"
msgstr "சுத்தம் செய்"

#: src/window/main_window.rs
msgid "Pruned 1 container"
msgid_plural "Pruned {n} containers"
msgstr[0] "1 கண்டெயினர் சுத்தம் செய்யப்பட்டது"
msgstr[1] "{n} கண்டெயினர்கள் சுத்தம் செய்யப்பட்டன"

#: src/window/main_window.rs
msgid "1 image"
msgid_plural "{n} images"
msgstr[0] "1 படம்"
msgstr[1] "{n} படங்கள்"

#: src/window/main_window.rs
msgid "Prune failed"
msgstr "சுத்தம் செய்வது தோல்வியடைந்தது"

